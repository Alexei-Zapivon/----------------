<UserControl x:Class="Lab3_MVVM_Variant9.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- Карточки со статистикой -->
            <TextBlock Text="Общая статистика" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,15">
                <Border Background="#2C3E50" CornerRadius="8" Padding="20,15" Margin="0,0,10,10" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Всего документов" Foreground="#AAA" FontSize="12"/>
                        <TextBlock Text="{Binding TotalCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#27AE60" CornerRadius="8" Padding="20,15" Margin="0,0,10,10" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Общая сумма" Foreground="#AAA" FontSize="12"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} руб.'}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#2980B9" CornerRadius="8" Padding="20,15" Margin="0,0,10,10" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="Квитанции" Foreground="#AAA" FontSize="12"/>
                        <TextBlock Text="{Binding ReceiptCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#16A085" CornerRadius="8" Padding="20,15" Margin="0,0,10,10" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="Накладные" Foreground="#AAA" FontSize="12"/>
                        <TextBlock Text="{Binding InvoiceCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#C0392B" CornerRadius="8" Padding="20,15" Margin="0,0,10,10" MinWidth="130">
                    <StackPanel>
                        <TextBlock Text="Счета" Foreground="#AAA" FontSize="12"/>
                        <TextBlock Text="{Binding BillCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Столбчатая диаграмма -->
            <TextBlock Text="Количество документов по типам" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <oxy:PlotView Model="{Binding BarModel}" Height="250" Margin="0,0,0,5"/>
            <Button Content="Экспорт в PNG" Command="{Binding ExportBarChartCommand}"
                    HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,15"/>

            <!-- Круговая диаграмма -->
            <TextBlock Text="Суммы по типам" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <oxy:PlotView Model="{Binding PieModel}" Height="300" Margin="0,0,0,5"/>
            <Button Content="Экспорт в PNG" Command="{Binding ExportPieChartCommand}"
                    HorizontalAlignment="Left" Padding="10,5"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
