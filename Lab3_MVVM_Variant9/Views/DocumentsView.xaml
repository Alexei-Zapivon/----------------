<UserControl x:Class="Lab3_MVVM_Variant9.Views.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск с debouncing -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="300" Height="32" FontSize="13" Padding="5,5"/>
            <TextBlock Text="(поиск с задержкой 400мс)" VerticalAlignment="Center"
                       Margin="10,0,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <!-- Список документов -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Documents}"
                  AutoGenerateColumns="False" IsReadOnly="False"
                  CanUserAddRows="False" RowHeight="30"
                  GridLinesVisibility="Horizontal">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TypeName}" Value="Квитанция">
                            <Setter Property="Background" Value="#EBF5FB"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TypeName}" Value="Накладная">
                            <Setter Property="Background" Value="#E9F7EF"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TypeName}" Value="Счёт">
                            <Setter Property="Background" Value="#FDEDEC"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"          Binding="{Binding Id}"          Width="45"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Тип"         Binding="{Binding TypeName}"    Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Название"    Binding="{Binding Title}"       Width="*"/>
                <DataGridTextColumn Header="Сумма, руб." Binding="{Binding Amount, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn Header="Дата"        Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Описание"    Binding="{Binding Description}" Width="200"/>
                <DataGridTemplateColumn Header="Удалить" Width="80" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Padding="4,2"
                                    Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма добавления -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Добавить документ" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Margin="0,0,10,5">
                        <TextBlock>
                            <Run Text="Название "/><Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" Padding="4"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,5">
                        <TextBlock>
                            <Run Text="Сумма "/><Run Text="*" Foreground="Red"/>
                        </TextBlock>
                        <TextBox Text="{Binding NewAmountText, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="28" Padding="4"/>
                        <TextBlock Text="{Binding ValidationError}" Foreground="Red" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,5">
                        <TextBlock Text="Описание"/>
                        <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" Padding="4"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,10,5">
                        <TextBlock Text="Тип"/>
                        <ComboBox SelectedIndex="{Binding NewTypeIndex}" Width="120" Height="28">
                            <ComboBoxItem Content="Квитанция"/>
                            <ComboBoxItem Content="Накладная"/>
                            <ComboBoxItem Content="Счёт"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Content="Добавить" Command="{Binding AddDocumentCommand}"
                            Width="100" Height="28" Margin="0,18,0,0"
                            Background="#2C3E50" Foreground="White"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
